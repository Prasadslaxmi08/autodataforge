# Copy to .env for local overrides. Env vars beat vds.toml.
# Nested keys use a double underscore: VDS_<SECTION>__<FIELD>.

# VDS_ENVIRONMENT=development
# VDS_LOG_LEVEL=DEBUG
# VDS_GPU__DEVICE=cuda
# VDS_GPU__VRAM_BUDGET_MB=8192
# VDS_STORAGE__DATABASE_URL=postgresql+psycopg://vds:vds@localhost:5432/vds
# VDS_MODELS__DETECTOR=vds.models.adapters.grounding_dino:GroundingDinoAdapter
